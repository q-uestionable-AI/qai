{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SecurityScanner",
          "semanticVersion": "1.2.3",
          "rules": [
            {
              "id": "SEC001",
              "name": "SQL Injection",
              "shortDescription": {"text": "Possible SQL injection vulnerability"},
              "fullDescription": {"text": "The application constructs SQL queries using unsanitized user input."},
              "defaultConfiguration": {"level": "error"},
              "properties": {
                "security-severity": "9.5",
                "tags": ["security", "sql", "injection"]
              }
            },
            {
              "id": "SEC002",
              "name": "Weak Crypto",
              "shortDescription": {"text": "Use of weak cryptographic algorithm"},
              "fullDescription": {"text": "The application uses MD5 for password hashing."},
              "defaultConfiguration": {"level": "warning"},
              "properties": {
                "security-severity": "5.0",
                "tags": ["security", "crypto"]
              }
            },
            {
              "id": "SEC003",
              "name": "Debug Logging",
              "shortDescription": {"text": "Debug logging enabled in production"},
              "fullDescription": {"text": "Verbose debug logging may expose sensitive information."},
              "defaultConfiguration": {"level": "note"}
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SEC001",
          "level": "error",
          "message": {"text": "SQL injection in login handler"},
          "properties": {
            "security-severity": "9.5"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {"uri": "src/auth.py"},
                "region": {"startLine": 42}
              }
            }
          ]
        },
        {
          "ruleId": "SEC002",
          "level": "warning",
          "message": {"text": "MD5 used for password hashing"},
          "properties": {
            "security-severity": "5.0"
          }
        },
        {
          "ruleId": "SEC003",
          "level": "note",
          "message": {"text": "Debug logging enabled in auth module"}
        }
      ]
    }
  ]
}
